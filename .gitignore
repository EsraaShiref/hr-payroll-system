## =====================================================================
## HR & Payroll System - .gitignore
## Covers: .NET 8/9 (Domain/Application/Infrastructure/Api), Angular 19+,
##         EF Core Migrations (KEPT), Hangfire, user secrets, IDE files
## =====================================================================

#############################################
# .NET Core / Visual Studio / Rider
#############################################

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
msbuild.log
msbuild.err
msbuild.wrn

# Visual Studio cache/options
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build outputs / artifacts
artifacts/
*.dll
*.pdb

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
coverage/
TestResults/

# ASP.NET Core / EF Core
*.pubxml
*.publishsettings
PublishProfiles/

# IMPORTANT: Keep EF Core migrations (tracked files), only ignore
# generated runtime artifacts inside Persistence (none by default —
# Migrations/ folders are SOURCE and must be committed)

# User Secrets (never commit secrets.json content/paths)
**/secrets.json
*.user.config

# Rider / JetBrains
.idea/
*.sln.iml

#############################################
# Sensitive Configuration
#############################################
appsettings.Development.json
appsettings.*.local.json
appsettings.Production.json
*.env
.env
.env.*
**/connectionstrings.json

#############################################
# NuGet
#############################################
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

#############################################
# Angular / Node (HRPayroll.WebUI)
#############################################
src/HRPayroll.WebUI/node_modules/
src/HRPayroll.WebUI/dist/
src/HRPayroll.WebUI/.angular/
src/HRPayroll.WebUI/.angular/cache/
src/HRPayroll.WebUI/coverage/
src/HRPayroll.WebUI/tmp/
src/HRPayroll.WebUI/out-tsc/
src/HRPayroll.WebUI/bazel-out/

# Angular environment files with secrets (keep templates, ignore real)
src/HRPayroll.WebUI/src/environments/environment.production.ts
src/HRPayroll.WebUI/src/environments/environment.local.ts

# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

#############################################
# Hangfire
#############################################
# Hangfire stores jobs in SQL Server (no local files by default),
# but ignore any local dashboard storage configs if present
**/hangfire-storage/

#############################################
# Serilog / Logs
#############################################
logs/
*.log
Logs/

#############################################
# Database (local dev only - never commit data files)
#############################################
*.mdf
*.ldf
*.ndf
*.bak

#############################################
# OS-specific
#############################################
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

#############################################
# Editor / Tooling
#############################################
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~.nib
*.code-workspace

#############################################
# AI Assistant / OpenCode artifacts (optional)
#############################################
.opencode/
*.session.json

#############################################
# Misc
#############################################
*.tmp
*.bak
*.cache